{
  "info": {
    "name": "Payment Gateway - Complete Collection",
    "description": "Requests for the payment gateway orchestrator. Run `npm run seed` before using the company API keys.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:3000", "type": "string" },
    { "key": "API_KEY_TICKETS", "value": "sk_tickets_abc123def456", "type": "string" },
    { "key": "TRANSACTION_ID", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/health"
      }
    },
    {
      "name": "Process Mastercard Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Api-Key", "value": "{{API_KEY_TICKETS}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 75000,\n  \"currency\": \"COP\",\n  \"pan\": \"5500005555555559\",\n  \"cvv\": \"321\",\n  \"cardHolder\": \"Jane Doe\",\n  \"externalReference\": \"TICKET-ORDER-001\",\n  \"description\": \"One VIP ticket\"\n}"
        },
        "url": "{{BASE_URL}}/api/payments/process-payment"
      }
    },
    {
      "name": "Get Transaction",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Api-Key", "value": "{{API_KEY_TICKETS}}" }
        ],
        "url": "{{BASE_URL}}/api/payments/{{TRANSACTION_ID}}"
      }
    },
    {
      "name": "Settlement Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Api-Key", "value": "{{API_KEY_TICKETS}}" }
        ],
        "url": "{{BASE_URL}}/api/settlements/summary"
      }
    },
    {
      "name": "Settlement Report",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Api-Key", "value": "{{API_KEY_TICKETS}}" }
        ],
        "url": "{{BASE_URL}}/api/settlements/report"
      }
    },
    {
      "name": "Settle Transactions",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Api-Key", "value": "{{API_KEY_TICKETS}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transactionIds\": [\n    \"{{TRANSACTION_ID}}\"\n  ]\n}"
        },
        "url": "{{BASE_URL}}/api/settlements/settle"
      }
    },
    {
      "name": "List Logs",
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/logs?transactionId={{TRANSACTION_ID}}"
      }
    }
  ]
}
